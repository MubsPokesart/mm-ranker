# Draft Management passcode gate.
# Generate with: node scripts/hash-passcode.mjs
# Copy the output into .env.local for dev, and into GitHub Actions secrets for the GH Pages deploy.
# Rotating the passcode is just: re-run the script, replace both values, redeploy.
# Users with the old cached passcode are automatically re-prompted on next visit.
VITE_DRAFT_MGMT_HASH=
VITE_DRAFT_MGMT_SALT=
